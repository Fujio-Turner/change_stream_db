{
  "gateway": {
    "src": "sync_gateway",
    "url": "http://host.docker.internal:4984",
    "database": "db",
    "scope": "us",
    "collection": "prices",
    "accept_self_signed_certs": false
  },
  "auth": {
    "method": "basic",
    "username": "bob",
    "password": "password",
    "session_cookie": "",
    "bearer_token": ""
  },
  "changes_feed": {
    "feed_type": "longpoll",
    "poll_interval_seconds": 10,
    "active_only": true,
    "include_docs": false,
    "since": "0",
    "channels": [],
    "limit": 0,
    "heartbeat_ms": 30000,
    "timeout_ms": 60000,
    "http_timeout_seconds": 300,
    "throttle_feed": 5000,
    "continuous_catchup_limit": 5000,
    "flood_threshold": 10000,
    "optimize_initial_sync": false
  },
  "threads": 4,
  "processing": {
    "ignore_delete": false,
    "ignore_remove": false,
    "sequential": false,
    "max_concurrent": 20,
    "dry_run": false,
    "get_batch_number": 100
  },
  "checkpoint": {
    "enabled": true,
    "client_id": "changes_worker",
    "file": "checkpoint.json",
    "every_n_docs": 0
  },
  "output": {
    "mode": "postgres",
    "postgres": {
      "host": "host.docker.internal",
      "port": 5432,
      "database": "YOUR_DB_NAME",
      "user": "YOUR_USER",
      "password": "YOUR_PASSWORD",
      "schema": "public",
      "ssl": false,
      "pool_min": 2,
      "pool_max": 10
    },
    "s3": {
      "bucket": "",
      "region": "us-east-1",
      "key_prefix": "couchdb-changes",
      "key_template": "{prefix}/{doc_id}.json",
      "key_sanitize": true,
      "content_type": "application/json",
      "storage_class": "",
      "server_side_encryption": "",
      "kms_key_id": "",
      "metadata": {},
      "endpoint_url": "",
      "access_key_id": "",
      "secret_access_key": "",
      "session_token": "",
      "on_delete": "delete",
      "batch": {
        "enabled": false,
        "max_docs": 100,
        "max_bytes": 1048576,
        "max_seconds": 5.0
      },
      "max_retries": 3,
      "backoff_base_seconds": 0.5,
      "backoff_max_seconds": 10
    },
    "target_url": "",
    "url_template": "{target_url}/{doc_id}",
    "write_method": "PUT",
    "delete_method": "DELETE",
    "send_delete_body": false,
    "request_timeout_seconds": 30,
    "accept_self_signed_certs": false,
    "follow_redirects": false,
    "target_auth": {
      "method": "none",
      "username": "",
      "password": "",
      "session_cookie": "",
      "bearer_token": ""
    },
    "retry": {
      "max_retries": 3,
      "backoff_base_seconds": 1,
      "backoff_max_seconds": 30,
      "retry_on_status": [500, 502, 503, 504]
    },
    "halt_on_failure": true,
    "data_error_action": "dlq",
    "log_response_times": true,
    "output_format": "json",
    "dead_letter_path": "failed_docs.jsonl",
    "dlq": {
      "retention_seconds": 86400,
      "max_replay_attempts": 10
    },
    "request_options": {
      "params": {},
      "headers": {}
    },
    "health_check": {
      "enabled": true,
      "interval_seconds": 30,
      "url": "",
      "method": "GET",
      "timeout_seconds": 5
    }
  },
  "retry": {
    "max_retries": 5,
    "backoff_base_seconds": 1,
    "backoff_max_seconds": 60,
    "retry_on_status": [500, 502, 503, 504]
  },
  "admin_ui": {
    "enabled": true,
    "host": "0.0.0.0",
    "port": 8080
  },
  "metrics": {
    "enabled": true,
    "host": "0.0.0.0",
    "port": 9090
  },
  "shutdown": {
    "drain_timeout_seconds": 60,
    "dlq_inflight_on_shutdown": false
  },
  "attachments": {
    "enabled": false,
    "dry_run": false,
    "mode": "individual",
    "filter": {
      "content_types": [],
      "reject_content_types": [],
      "min_size_bytes": 0,
      "max_size_bytes": 0,
      "max_total_bytes_per_doc": 0,
      "name_pattern": "",
      "ignore_revpos": false
    },
    "fetch": {
      "use_bulk_get": false,
      "max_concurrent_downloads": 5,
      "max_concurrent_downloads_global": 20,
      "request_timeout_seconds": 120,
      "temp_dir": "/tmp/attachments",
      "stream_to_disk_threshold_bytes": 10485760,
      "verify_digest": true,
      "verify_length": true
    },
    "destination": {
      "type": "s3",
      "key_template": "{prefix}/{doc_id}/{attachment_name}",
      "key_prefix": "attachments",
      "s3": {
        "bucket": "",
        "region": "us-east-1",
        "endpoint_url": "",
        "access_key_id": "",
        "secret_access_key": "",
        "session_token": "",
        "storage_class": "",
        "server_side_encryption": "",
        "kms_key_id": "",
        "metadata": {}
      },
      "http": {
        "url_template": "",
        "method": "PUT",
        "headers": {}
      },
      "filesystem": {
        "base_path": "",
        "dir_template": "{doc_id}",
        "preserve_filename": true
      }
    },
    "post_process": {
      "action": "none",
      "update_field": "attachments_external",
      "remove_attachments_after_upload": false,
      "ttl_seconds": 86400,
      "on_doc_missing": "skip",
      "max_conflict_retries": 3,
      "cleanup_orphaned_uploads": false
    },
    "retry": {
      "max_retries": 3,
      "backoff_base_seconds": 1,
      "backoff_max_seconds": 30,
      "retry_on_status": [408, 429, 500, 502, 503, 504]
    },
    "on_missing_attachment": "skip",
    "partial_success": "continue",
    "halt_on_failure": true,
    "skip_on_edge_server": true
  },
  "couchbase_lite": {
    "db_dir": "/app/data",
    "db_name": "changes_worker_db",
    "maintenance": {
      "enabled": true,
      "interval_hours": 24
    }
  },
  "logging": {
    "redaction_level": "partial",
    "console": {
      "enabled": true,
      "log_level": "info",
      "log_keys": ["*"],
      "key_levels": {},
      "color_enabled": false
    },
    "file": {
      "enabled": true,
      "path": "logs/changes_worker.log",
      "log_level": "debug",
      "log_keys": ["*"],
      "key_levels": {},
      "rotation": {
        "max_size": 100,
        "max_age": 7,
        "rotated_logs_size_limit": 1024
      }
    }
  },
  "collect": {
    "tmp_dir": "/tmp",
    "max_log_size_mb": 200,
    "profile_seconds": 5,
    "system_command_timeout_seconds": 30,
    "include_cbl_logs": true,
    "default_redaction": "partial"
  }
}
