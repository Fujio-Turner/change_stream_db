{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/changes-worker/outputs_cloud.schema.json",
  "title": "Cloud Output Configuration",
  "description": "Defines cloud service destinations (AWS S3, Google Cloud Storage, Azure Blob, etc.)",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "const": "outputs_cloud",
      "description": "Document type identifier"
    },
    "src": {
      "type": "array",
      "description": "Array of cloud storage definitions",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for this cloud storage destination"
          },
          "cloud_provider": {
            "type": "string",
            "enum": [
              "aws_s3",
              "gcs",
              "azure_blob",
              "oracle_ocs"
            ],
            "description": "Cloud provider type"
          },
          "bucket": {
            "type": "string",
            "description": "Bucket or container name"
          },
          "region": {
            "type": ["string", "null"],
            "description": "Cloud region"
          },
          "prefix": {
            "type": ["string", "null"],
            "description": "Key prefix or path prefix for objects"
          },
          "access_key": {
            "type": ["string", "null"],
            "description": "Access key or API key (should be encrypted)"
          },
          "secret_key": {
            "type": ["string", "null"],
            "description": "Secret key or API secret (should be encrypted)"
          },
          "format": {
            "type": ["string", "null"],
            "enum": [
              "json",
              "jsonl",
              "parquet",
              "csv",
              "avro"
            ],
            "default": "jsonl",
            "description": "Data format for stored objects"
          },
          "compression": {
            "type": ["string", "null"],
            "enum": [
              "none",
              "gzip",
              "snappy",
              "brotli"
            ],
            "default": "none",
            "description": "Compression algorithm"
          },
          "batch_size": {
            "type": ["integer", "null"],
            "default": 1000,
            "description": "Number of documents per upload"
          }
        },
        "required": ["id", "cloud_provider", "bucket"],
        "additionalProperties": true
      }
    },
    "meta": {
      "type": ["object", "null"],
      "description": "Metadata for tracking and audit purposes"
    },
    "updated_at": {
      "type": ["string", "null"],
      "format": "date-time",
      "description": "ISO 8601 timestamp of last update"
    }
  },
  "required": ["type", "src"],
  "additionalProperties": true,
  "examples": [
    {
      "type": "outputs_cloud",
      "src": [
        {
          "id": "s3-data-lake",
          "cloud_provider": "aws_s3",
          "bucket": "my-data-lake",
          "region": "us-east-1",
          "prefix": "changes/v1/",
          "format": "parquet",
          "compression": "snappy",
          "batch_size": 5000
        }
      ]
    }
  ]
}
