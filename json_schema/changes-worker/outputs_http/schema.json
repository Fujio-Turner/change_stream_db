{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/changes-worker/outputs_http.schema.json",
  "title": "HTTP Output Configuration",
  "description": "Defines HTTP/REST endpoints for pushing processed data",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "const": "outputs_http",
      "description": "Document type identifier"
    },
    "src": {
      "type": "array",
      "description": "Array of HTTP endpoint definitions",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for this HTTP endpoint"
          },
          "url": {
            "type": "string",
            "format": "uri",
            "description": "HTTP endpoint URL"
          },
          "method": {
            "type": "string",
            "enum": [
              "POST",
              "PUT",
              "PATCH"
            ],
            "default": "POST",
            "description": "HTTP method for operations"
          },
          "headers": {
            "type": ["object", "null"],
            "description": "HTTP headers to include in requests",
            "additionalProperties": {
              "type": "string"
            }
          },
          "auth_type": {
            "type": ["string", "null"],
            "enum": [
              "none",
              "basic",
              "bearer",
              "api_key"
            ],
            "default": "none",
            "description": "Authentication type"
          },
          "auth_credentials": {
            "type": ["object", "null"],
            "description": "Authentication credentials (username/password or token)"
          },
          "timeout_seconds": {
            "type": ["integer", "null"],
            "default": 30,
            "description": "Request timeout in seconds"
          },
          "retry_count": {
            "type": ["integer", "null"],
            "default": 3,
            "description": "Number of retry attempts"
          },
          "batch_size": {
            "type": ["integer", "null"],
            "default": 50,
            "description": "Number of documents per batch request"
          }
        },
        "required": ["id", "url"],
        "additionalProperties": true
      }
    },
    "meta": {
      "type": ["object", "null"],
      "description": "Metadata for tracking and audit purposes"
    },
    "updated_at": {
      "type": ["string", "null"],
      "format": "date-time",
      "description": "ISO 8601 timestamp of last update"
    }
  },
  "required": ["type", "src"],
  "additionalProperties": true,
  "examples": [
    {
      "type": "outputs_http",
      "src": [
        {
          "id": "api-webhook",
          "url": "https://webhook.example.com/ingest",
          "method": "POST",
          "headers": {
            "Content-Type": "application/json"
          },
          "auth_type": "bearer",
          "auth_credentials": {
            "token": "secret-token-xyz"
          },
          "timeout_seconds": 60,
          "retry_count": 5,
          "batch_size": 100
        }
      ]
    }
  ]
}
